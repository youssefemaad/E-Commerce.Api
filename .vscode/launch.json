{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch E-Commerce API",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/E-Commerce.Web/bin/Debug/net8.0/E-Commerce.Web.dll",
            "args": [],
            "cwd": "${workspaceFolder}/E-Commerce.Web",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
                "uriFormat": "%s"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            }
        }
    ]
}